<div id="mycompany-admin" class="mc-admin" data-plugin="{{pluginShortName}}">
    <h2>My Company</h2>
    <div class="mc-admin-subtitle">Consolidated plugin administration</div>
    <div class="mc-admin-tabs">
        <button type="button" data-tab="overview" class="active">Overview</button>
        <button type="button" data-tab="settings">Settings</button>
        <button type="button" data-tab="plugins">Wtyczki</button>
        <button type="button" data-tab="server">Serwer</button>
        <button type="button" data-tab="debug">Debug</button>
    </div>
    <div id="mycompany-admin-content"></div>
</div>
<script>window.MyCompanyAdminData={{{adminDataJson}}};</script>
<link rel="stylesheet" href="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin.css">
<link rel="stylesheet" href="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-ui-enhancements.css">
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin.js"></script>
<script>
(function(){
"use strict";
var root=document.getElementById("mycompany-admin"),content=document.getElementById("mycompany-admin-content");
if(!root||!content)return;
function portal(){var d=window.MyCompanyAdminData||{},s=d.moduleSettings||{};return s.portal||{};}
function field(card,label,value,type,description){var wrap=document.createElement("label");wrap.className="mc-admin-field mc-admin-portal-branding-field";var title=document.createElement("span");title.className="mc-admin-field-label";title.textContent=label;wrap.appendChild(title);var input=document.createElement("input");input.className="mc-admin-input";input.type=type||"text";input.value=value||"";wrap.appendChild(input);if(description){var small=document.createElement("small");small.textContent=description;wrap.appendChild(small);}card.appendChild(wrap);return input;}
function check(card,label,checked,description){var row=document.createElement("label");row.className="mc-admin-check mc-admin-portal-branding-field";var input=document.createElement("input");input.type="checkbox";input.checked=checked;row.appendChild(input);var text=document.createElement("span");var strong=document.createElement("strong");strong.textContent=label;text.appendChild(strong);if(description){var small=document.createElement("small");small.textContent=description;text.appendChild(small);}row.appendChild(text);card.appendChild(row);return input;}
function post(values){var url=new URL("pluginadmin.ashx",location.href);url.searchParams.set("pin",root.getAttribute("data-plugin")||"MyCompany");url.searchParams.set("module","portal");url.searchParams.set("asset","settings");var body=new URLSearchParams();body.set("payload",JSON.stringify(values));return fetch(url.href,{method:"POST",credentials:"same-origin",headers:{"Content-Type":"application/x-www-form-urlencoded; charset=UTF-8"},body:body.toString()}).then(function(r){return r.text().then(function(t){var v;try{v=JSON.parse(t||"{}");}catch(e){throw new Error(t||("HTTP "+r.status));}if(!r.ok||v.ok===false)throw new Error(v.error||("HTTP "+r.status));return v;});});}
function enhance(){var card=content.querySelector(".mc-admin-card");if(!card||card.querySelector("[data-portal-branding-fields]"))return;var heading=Array.prototype.find.call(card.querySelectorAll("h3"),function(h){return h.textContent.trim()==="Portal interface";});if(!heading)return;var current=portal(),host=document.createElement("div");host.setAttribute("data-portal-branding-fields","1");host.className="mc-admin-portal-branding";var showReset=check(host,"Pokazuj przycisk resetu hasła",current.showPasswordReset!==false,"Przycisk jest wyświetlany na nowym ekranie logowania SirK Portal.");var resetUrl=field(host,"Adres resetu hasła",current.passwordResetUrl||"https://passwordreset.microsoftonline.com/","url","Dozwolone są adresy HTTP i HTTPS.");var siteName=field(host,"Nazwa witryny",current.siteName||"SirK Portal","text","Nazwa pojawi się w menu Portalu, ekranie logowania i tytule karty.");siteName.maxLength=80;var iconUrl=field(host,"Adres ikony witryny",current.siteIconUrl||"","url","Ikona zostanie użyta jako favicon oraz logo na stronie i ekranie logowania.");card.appendChild(host);function toggle(){resetUrl.disabled=!showReset.checked;}showReset.addEventListener("change",toggle);toggle();var save=content.querySelector(".mc-admin-settings-savebar .mc-admin-primary");if(!save||save.getAttribute("data-branding-save-wrapped")==="1")return;save.setAttribute("data-branding-save-wrapped","1");var original=save.onclick;save.onclick=function(event){save.disabled=true;post({showPasswordReset:showReset.checked,passwordResetUrl:resetUrl.value,siteName:siteName.value,siteIconUrl:iconUrl.value}).then(function(result){var d=window.MyCompanyAdminData||{};d.moduleSettings=d.moduleSettings||{};d.moduleSettings.portal=result.module||d.moduleSettings.portal||{};if(typeof original==="function")original.call(save,event);}).catch(function(error){save.disabled=false;var status=content.querySelector(".mc-admin-save-status");if(status){status.className="mc-admin-save-status mc-admin-error";status.textContent=error.message||String(error);}});};}
new MutationObserver(function(){setTimeout(enhance,0);}).observe(content,{childList:true,subtree:true});setTimeout(enhance,0);
}());
</script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-approval-policy.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-layout.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-ui-enhancements.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-plugin-updates.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-marketplace.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-move-mesh-levels.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-portal.js"></script>