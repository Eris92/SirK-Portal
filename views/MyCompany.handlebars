<div id="mycompany-admin" class="mc-admin" data-plugin="{{pluginShortName}}">
    <h2>My Company</h2>
    <div class="mc-admin-subtitle">Consolidated plugin administration</div>
    <div class="mc-admin-tabs">
        <button type="button" data-tab="overview" class="active">Overview</button>
        <button type="button" data-tab="settings">Settings</button>
        <button type="button" data-tab="plugins">Wtyczki</button>
        <button type="button" data-tab="server">Serwer</button>
        <button type="button" data-tab="debug">Debug</button>
    </div>
    <div id="mycompany-admin-content"></div>
</div>
<script>window.MyCompanyAdminData={{{adminDataJson}}};</script>
<link rel="stylesheet" href="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin.css">
<link rel="stylesheet" href="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-ui-enhancements.css">
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin.js"></script>
<script>
(function () {
    "use strict";
    document.addEventListener("click", function (event) {
        var save = event.target && event.target.closest && event.target.closest(".mc-admin-settings-savebar .mc-admin-primary");
        if (!save) return;
        document.querySelectorAll(".mc-admin-check input[type=checkbox]").forEach(function (input) {
            var label = input.closest(".mc-admin-check");
            if (label && label.textContent.indexOf("Dostęp dla wszystkich użytkowników") >= 0) input.dispatchEvent(new Event("change", { bubbles: true }));
        });
    }, true);
}());
</script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-approval-policy.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-layout.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-ui-enhancements.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-plugin-updates.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-marketplace.js"></script>
<script>
(function () {
    "use strict";
    if (window.__myCompanyPluginRollbackLoaded) return;
    window.__myCompanyPluginRollbackLoaded = true;
    var root = document.getElementById("mycompany-admin"), content = document.getElementById("mycompany-admin-content");
    if (!root || !content) return;
    var plugins = [];
    function pin(){return root.getAttribute("data-plugin")||"MyCompany";}
    function parse(r){return r.text().then(function(t){var v;try{v=JSON.parse(t||"{}");}catch(e){throw new Error(t||("HTTP "+r.status));}if(!r.ok||v.ok===false)throw new Error(v.error||("HTTP "+r.status));return v;});}
    function post(operation,payload){var body=new URLSearchParams();payload=payload||{};payload.operation=operation;body.set("payload",JSON.stringify(payload));var url=new URL("pluginadmin.ashx",window.location.href);url.searchParams.set("pin",pin());url.searchParams.set("action","plugin-operation");return fetch(url.href,{method:"POST",credentials:"same-origin",headers:{"Content-Type":"application/x-www-form-urlencoded; charset=UTF-8"},body:body.toString()}).then(parse);}
    function status(text,error){var h=content.querySelector(".mc-admin-save-status");if(h){h.className=error?"mc-admin-save-status mc-admin-error":"mc-admin-save-status";h.textContent=text||"";}}
    function plugin(shortName){shortName=String(shortName||"").toLowerCase();return plugins.find(function(p){return String(p.shortName||"").toLowerCase()===shortName;});}
    function date(value){try{return new Date(value).toLocaleString("pl-PL");}catch(e){return value||"—";}}
    function closePanel(){var p=content.querySelector("[data-plugin-backup-panel]");if(p)p.remove();}
    function showBackups(value){closePanel();var panel=document.createElement("section");panel.className="mc-admin-card";panel.setAttribute("data-plugin-backup-panel","1");var title=document.createElement("h3");title.textContent="Backupy — "+(value.plugin.name||value.plugin.shortName);panel.appendChild(title);var desc=document.createElement("div");desc.className="mc-admin-card-description";desc.textContent="Przywrócenie tworzy dodatkową kopię bieżącej wersji. Po operacji wymagany jest restart MeshCentral.";panel.appendChild(desc);var table=document.createElement("table");table.className="mc-admin-table";table.innerHTML="<thead><tr><th>Wersja</th><th>Data</th><th>Typ</th><th>Akcje</th></tr></thead>";var body=document.createElement("tbody");(value.backups||[]).forEach(function(b){var row=document.createElement("tr");row.innerHTML="<td></td><td></td><td></td><td></td>";row.children[0].textContent=b.version||"—";row.children[1].textContent=date(b.createdAt);row.children[2].textContent=b.reason||"backup";var restore=document.createElement("button");restore.type="button";restore.className="mc-admin-primary";restore.textContent="Przywróć";restore.onclick=function(){if(!window.confirm("Przywrócić "+(value.plugin.name||value.plugin.shortName)+" do wersji "+b.version+"? Bieżący stan zostanie zabezpieczony w nowym backupie."))return;restore.disabled=true;status("Przywracanie backupu…",false);post("rollback",{id:value.plugin.id,backupId:b.id}).then(function(result){status("Przywrócono wersję "+(result.result&&result.result.version||b.version)+". Zrestartuj usługę MeshCentral.",false);plugins=result.plugins||plugins;closePanel();}).catch(function(error){status(error.message||String(error),true);restore.disabled=false;});};row.children[3].appendChild(restore);body.appendChild(row);});table.appendChild(body);panel.appendChild(table);if(!(value.backups||[]).length){var empty=document.createElement("div");empty.className="mc-admin-notice";empty.textContent="Brak backupów dla tej wtyczki.";panel.appendChild(empty);}var close=document.createElement("button");close.type="button";close.className="mc-admin-secondary";close.textContent="Zamknij";close.onclick=closePanel;panel.appendChild(close);var wrap=content.querySelector(".mc-admin-table-wrap");if(wrap&&wrap.nextSibling)content.insertBefore(panel,wrap.nextSibling);else content.appendChild(panel);}
    function enhance(){var table=content.querySelector(".mc-admin-plugin-table");if(!table)return;table.querySelectorAll("tbody tr").forEach(function(row){var n=row.querySelector(".mc-admin-plugin-name small"),actions=row.querySelector(".mc-admin-table-actions");if(!n||!actions||actions.querySelector("[data-plugin-backups-button]"))return;var p=plugin(n.textContent);if(!p)return;var button=document.createElement("button");button.type="button";button.className="mc-admin-secondary mc-admin-plugin-update-button";button.setAttribute("data-plugin-backups-button","1");button.textContent="Backupy ("+(p.backupCount||0)+")";button.onclick=function(){button.disabled=true;status("Ładowanie backupów…",false);post("backups",{id:p.id}).then(function(result){showBackups(result.result||{});status("",false);}).catch(function(error){status(error.message||String(error),true);}).then(function(){button.disabled=false;});};actions.insertBefore(button,actions.firstChild);});}
    function refresh(){var url=new URL("pluginadmin.ashx",window.location.href);url.searchParams.set("pin",pin());url.searchParams.set("action","plugin-state");fetch(url.href,{credentials:"same-origin",cache:"no-store"}).then(parse).then(function(r){plugins=r.plugins||[];enhance();}).catch(function(){});}
    new MutationObserver(function(){if(plugins.length)enhance();else if(content.querySelector(".mc-admin-plugin-table"))refresh();}).observe(content,{childList:true,subtree:true});
    refresh();
}());
</script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-move-mesh-levels.js"></script>
<script src="pluginadmin.ashx?pin={{pluginShortName}}&asset=admin-portal.js"></script>
